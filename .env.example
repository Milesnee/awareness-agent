# 微信服务号
WECHAT_TOKEN=
WECHAT_APPID=
WECHAT_SECRET=
WECHAT_AES_KEY=
# LLM 路由链（依序故障转移）：glm / deepseek / qwen / mock，或 LLM_EXTRA_PROVIDERS 注册的名字
LLM_CHAIN=glm,deepseek
GLM_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
# 自定义 provider（OpenAI 兼容端点）
# LLM_EXTRA_PROVIDERS=[{"name":"kimi","base_url":"https://api.moonshot.cn/v1","model":"moonshot-v1-8k","api_key_env":"MOONSHOT_API_KEY"}]
SESSION_ROUND_LIMIT=5
# 记忆系统嵌入（OpenAI 兼容 /embeddings；留 mock:// 为本地联调）
EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4
EMBEDDING_MODEL=embedding-3
EMBEDDING_API_KEY=
# R2 语音（公众平台先开启「接收语音识别结果」，ASR 即零成本；以下为可选增强）
ASR_BASE_URL=
ASR_API_KEY=
TTS_BASE_URL=
TTS_MODEL=
TTS_VOICE=
TTS_API_KEY=
